{
  "name": "@php-workx/skill-codereview",
  "version": "1.2.0",
  "description": "Local AI code review skill for Claude Code and Codex. Explorer-judge architecture with deterministic scans, spec verification, and chunked review for large diffs.",
  "keywords": [
    "skill",
    "claude",
    "codex",
    "cursor",
    "code-review",
    "ai-agent",
    "openskills",
    "security",
    "testing",
    "spec-verification"
  ],
  "scripts": {
    "validate": "bash -n skills/codereview/scripts/validate_output.sh && bash -n scripts/install-codereview-skill.sh && bash -n scripts/ci-local-release.sh",
    "prepublishOnly": "npm run validate"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/php-workx/skill-codereview.git"
  },
  "license": "MIT",
  "files": [
    "skills/",
    "prompts/",
    "scripts/",
    "README.md",
    "LICENSE"
  ]
}
