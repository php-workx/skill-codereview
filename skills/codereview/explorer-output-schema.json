{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Explorer Output",
  "description": "Output schema for codereview explorer sub-agents. Supports 3 shapes: bare findings array, findings+requirements object, or full object with certification and completeness gate.",
  "oneOf": [
    {
      "type": "array",
      "description": "Bare findings array (legacy format)",
      "items": { "$ref": "#/$defs/finding" }
    },
    {
      "type": "object",
      "description": "Object with findings and optional requirements",
      "required": ["findings"],
      "properties": {
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" }
        },
        "requirements": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Spec requirements (from spec-verification explorer)"
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "description": "Full object with certification and completeness gate (post-F5/F6)",
      "required": ["findings"],
      "properties": {
        "certification": {
          "type": "object",
          "description": "Per-file certification data from explorer",
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "file": { "type": "string" },
                  "certified": { "type": "boolean" },
                  "reason": { "type": "string" }
                }
              }
            }
          }
        },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" }
        },
        "requirements": {
          "type": "array",
          "items": { "type": "object" }
        },
        "completeness_gate": {
          "type": "object",
          "description": "Completeness gate data",
          "properties": {
            "passed": { "type": "boolean" },
            "coverage": { "type": "number" },
            "gaps": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": false
    }
  ],
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["summary"],
      "properties": {
        "pass": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 0 },
        "summary": { "type": "string" },
        "evidence": { "type": ["string", "null"] },
        "evidence_source": { "type": ["string", "null"] },
        "failure_mode": { "type": ["string", "null"] },
        "fix": { "type": ["string", "null"] },
        "tests_to_add": { "type": "array", "items": { "type": "string" } },
        "test_category_needed": { "type": "array", "items": { "type": "string" } },
        "test_level": { "type": ["string", "null"] },
        "bug_finding_level": { "type": ["string", "null"] },
        "gap_reason": { "type": ["string", "null"] }
      }
    }
  }
}
